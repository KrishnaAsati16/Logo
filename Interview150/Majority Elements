class Solution {
    public int majorityElement(int[] nums) {
          int majorityCandidate = nums[0];
        int majorityCount = 1;

        for (int i = 1; i < nums.length; i++) {

            if (nums[i] == majorityCandidate) {
                majorityCount++;
            } else {
                majorityCount--;
            }

            if (majorityCount == 0) {
                majorityCandidate = nums[i];
                majorityCount = 1;
            }
        }

        return majorityCandidate;
}
}
