class Solution {
    public String predictPartyVictory(String senate) {
        int n = senate.length();
        boolean[] banned = new boolean[n];
        int banR = 0, banD = 0;

        while (true) {
            boolean radiantAlive = false, direAlive = false;

            for (int i = 0; i < n; i++) {
                if (banned[i]) continue;

                char c = senate.charAt(i);
                if (c == 'R') {
                    if (banR > 0) {
                        banned[i] = true;
                        banR--;
                    } else {
                        banD++; // Radiant bans a Dire senator
                        radiantAlive = true;
                    }
                } else {
                    if (banD > 0) {
                        banned[i] = true;
                        banD--;
                    } else {
                        banR++; // Dire bans a Radiant senator
                        direAlive = true;
                    }
                }
            }

            if (!radiantAlive) return "Dire";
            if (!direAlive) return "Radiant";
        }
    }
}
