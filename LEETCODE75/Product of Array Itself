class Solution {
    public int[] productExceptSelf(int[] nums) {
         int n = nums.length;
            int ans[] = new int [n];
            int productright = 1;
             int productleft = 1;

             // reverse loop 
             for(int i = n-1; i>=0;i--) // last to first element
               {
                ans[i] = productright;
                productright = productright*nums[i];
               }
               for( int i = 0; i<n ; i++)
               {
                 ans[i] =  ans[i]*productleft;
                productleft = productleft*nums[i];
               }
           return ans;     
        }
    }
