class Solution {
    public int[] successfulPairs(int[] spells, int[] potions, long success) {
        Arrays.sort(potions); // Sort potions for binary search
        int n = spells.length;
        int m = potions.length;
        int[] result = new int[n];

        for (int i = 0; i < n; i++) {
            int spell = spells[i];
            // Find the first potion index where spell * potion >= success
            int idx = binarySearch(potions, spell, success);
            result[i] = m - idx; // Count of successful potions
        }
        return result;
    }

    private int binarySearch(int[] potions, int spell, long success) {
        int left = 0, right = potions.length - 1;
        while (left <= right) {
            int mid = left + (right - left) / 2;
            long product = (long) spell * potions[mid];
            if (product >= success) {
                right = mid - 1; // look for earlier index
            } else {
                left = mid + 1;
            }
        }
        return left; // first index where product >= success
    }
}
