
class RecentCounter {
    private Queue<Integer> q;

    public RecentCounter() {
        q = new LinkedList<>();
    }

    public int ping(int t) {
        // Add the new request
        q.add(t);

        // Remove requests older than t - 3000
        while (q.peek() < t - 3000) {
            q.poll();
        }

        // Return the number of recent requests
        return q.size();
    }
}
